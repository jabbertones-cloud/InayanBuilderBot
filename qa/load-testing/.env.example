# K6 Load Testing Environment Configuration
# Copy this file to .env and update values as needed

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# The base URL of the MorningOps Desktop backend to test
# For local development:
BASE_URL=http://localhost:3000

# For staging environment:
# BASE_URL=https://staging-api.morningops.app

# For production (use with caution):
# BASE_URL=https://api.morningops.app

# ============================================================================
# K6 CLOUD CONFIGURATION (Optional)
# ============================================================================

# Enable K6 Cloud for distributed load testing
# Requires k6 login cloud (https://cloud.k6.io)
K6_CLOUD=false

# K6 Cloud API token (optional, for automated uploads)
# K6_CLOUD_TOKEN=your_token_here

# ============================================================================
# TEST CONFIGURATION
# ============================================================================

# Default number of virtual users (can be overridden per test)
K6_VUS=1

# Default test duration (can be overridden per test)
K6_DURATION=1m

# Log level: trace, debug, info, warn, error
K6_LOG_LEVEL=info

# ============================================================================
# STRIPE TEST CONFIGURATION
# ============================================================================

# Test mode Stripe webhook secret (for local testing)
# This is NOT the real secret - for testing only
STRIPE_WEBHOOK_SECRET=whsec_test_

# Stripe API key for test mode (if making actual API calls in tests)
# STRIPE_API_KEY=sk_test_

# ============================================================================
# PERFORMANCE TARGETS
# ============================================================================

# These can be referenced in test scenarios for dynamic thresholds
TARGET_P95_LATENCY_MS=500
TARGET_ERROR_RATE=0.01
TARGET_AVAILABILITY_PERCENT=99.0

# ============================================================================
# ADVANCED OPTIONS
# ============================================================================

# Skip SSL certificate verification (development only!)
# K6_INSECURE_SKIP_TLS_VERIFY=false

# DNS server to use (optional)
# K6_DNS_SERVER=8.8.8.8

# HTTP proxy (optional)
# K6_PROXY=http://proxy.example.com:3128

# ============================================================================
# RESULT OUTPUT
# ============================================================================

# Output results to file (HTML format - requires extension)
# K6_OUT=html=./results/test-result.html

# Output to JSON
# K6_OUT=json=./results/test-result.json

# Output to stdout
# K6_OUT=json

# ============================================================================
# EXAMPLE USAGES
# ============================================================================

# Run smoke test against local backend:
# k6 run scenarios/api-smoke.js

# Run with custom BASE_URL:
# k6 run --env BASE_URL=https://staging.morningops.app scenarios/api-smoke.js

# Run with different VU count:
# k6 run --vus 50 --duration 5m scenarios/email-sync-load.js

# Run with cloud output:
# k6 run --cloud scenarios/api-smoke.js
