# InayanBuilderBot — template configuration
# Copy to .env and fill in your actual values. NEVER commit .env.

NODE_ENV=development
PORT=3000

# BuilderBot API Key
BUILDERBOT_API_KEY=your_builderbot_api_key_here

# CORS and security
ALLOWED_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Code indexing
GITHUB_TOKEN=your_github_token_here
CLAW_ARCHITECT_ROOT=/path/to/claw-architect
EXTERNAL_INDEXING_MODE=builtin

# LLM API Keys (optional - uncomment to use)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_CHAT_MODEL=gpt-4o-mini

# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_API_KEY=your_claude_api_key_here
# ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
# CLAUDE_CHAT_MODEL=claude-3-5-sonnet-latest

# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
